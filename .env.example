# === Provider AI (pilih salah satu) ===
# Pilihan: "groq" (gratis, default) | "openai" | "anthropic"
AI_PROVIDER=groq

# (Opsional) Override model. Kosongkan untuk pakai default tiap provider.
# groq default      : meta-llama/llama-4-scout-17b-16e-instruct
#   alternatif kuat : openai/gpt-oss-120b   (reasoning lebih baik, tetap gratis di Groq)
# openai default    : gpt-4o-mini
# anthropic default : claude-sonnet-4-5-20250929
AI_MODEL=

# --- API key sesuai provider yang dipilih ---
# Groq (gratis, tanpa kartu): https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxx
# OPENAI_API_KEY=sk-xxxx
# ANTHROPIC_API_KEY=sk-ant-xxxx

# (Opsional) email kontak ke OpenAlex — akses lebih cepat
OPENALEX_MAILTO=kamu@email.com

# Stage 2 (auth + persistensi). Tidak diperlukan untuk MVP.
# DATABASE_URL=postgresql://user:pass@localhost:5432/rizaai
